{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist-electron",
    "rootDir": "electron",
    "resolveJsonModule": true,
    "declaration": false
  },
  "include": ["electron/**/*"],
  "exclude": ["electron/**/*.test.ts"]
}
